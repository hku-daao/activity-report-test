# Copy to ".env" and fill in values. Restart `npm run dev` after changes.

# Firebase — https://console.firebase.google.com → Project settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Folder for uploaded Proactive Initiative attachments (bucket root; no leading/trailing /).
# Storage rules should scope access under this path to signed-in users as needed, e.g.:
#   match /{allPaths=**} { allow read, write: if request.auth != null; }
# Tighten with path prefixes matching your UIDs in production.
VITE_FIREBASE_STORAGE_ATTACHMENTS_PREFIX=attachments

# Access list — staff, team, subordinate (can be its own Supabase project)
# https://supabase.com/dashboard → Project → Settings → API
VITE_ACCESS_SUPABASE_URL=
VITE_ACCESS_SUPABASE_ANON_KEY=

# App profiles — Firebase user rows (`profiles` table); use a different project if you prefer
VITE_PROFILES_SUPABASE_URL=
VITE_PROFILES_SUPABASE_ANON_KEY=
